# ingest_work/.env.example
# Kopieren nach .env und Werte eintragen

# --- Keys ---
MISTRAL_API_KEY=CHANGEME

# --- Datenbank (Pflicht, kein Fallback) ---
KOMMRAG_DSN=postgresql://USER:PASSWORT@127.0.0.1:5432/kommrag?client_encoding=utf8

# --- Pipeline ---
# Mindest-Matchscore (0-100) für Segment-Akzeptanz
PIPELINE_SCORE_THRESHOLD=90

# --- Mistral Endpoints/Modelle (optional, Defaults im Code) ---
MISTRAL_OCR_URL=https://api.mistral.ai/v1/ocr
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_MODEL=mistral-large-latest

# --- Validator ---
VALIDATE_MIN_TOP_CHARS=20
VALIDATE_MARKER_NEAR_START_CHARS=600
VALIDATE_LEAKAGE_EARLY_WINDOW=1400

# --- Document AI ---
DOCAI_TIMEOUT_S=300

# --- Repair ---
REPAIR_WINDOW_PAD=2
REPAIR_WINDOW_PAD_RETRY=6
REPAIR_FALLBACK_FIRST_PAGES=6
REPAIR_PER_PAGE_CHAR_CAP=20000
REPAIR_TIMEOUT_S=180
